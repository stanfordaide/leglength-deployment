{
    "process": {
        "settings": {
            "models": ["rn50adncti", "rn50adkpncti", "rn50adkp"],
            "series_offset": 1000,
            "femur_threshold": 0.2,
            "tibia_threshold": 0.2,
            "total_threshold": 1.0,
            "confidence_threshold": 0.0,
            "num_threads": 2,
            "max_input_files": null,
            "monitoring": {
                "enabled": true,
                "influxdb": {
                    "url": "http://localhost:9051",
                    "token": "ai-inference-token-12345",
                    "org": "mercure-ai",
                    "bucket": "ai-inference-spc",
                    "timeout": 5.0
                },
                "prometheus": {
                    "gateway_url": "http://localhost:9053",
                    "job_name": "pediatric-leglength",
                    "instance": "pediatric-leglength-module",
                    "timeout": 5.0
                },
                "metrics": {
                    "collection_interval": 10,
                    "batch_size": 50,
                    "include_system_metrics": true,
                    "include_model_metrics": true
                }
            },
            "results_db": {
                "enabled": true,
                "host": "172.17.0.1",
                "port": 9042,
                "database": "monitoring",
                "user": "monitoring",
                "password": "monitoring123"
            }
        }
    }
}
